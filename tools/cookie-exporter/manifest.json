{
  "manifest_version": 3,
  "name": "Cookie JSON Exporter",
  "version": "1.0",
  "description": "Export all browser cookies or current tab cookies to a JSON file.",
  "permissions": [
    "cookies",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookie Exporter"
  }
}
